+export interface DriverDocumentsSummaryInput {
+  approved: number
+  rejected: number
+  pending: number
+  notSubmitted: number
+  total: number
+  globalStatus: 'all_approved' | 'has_rejected' | 'pending'
+}
+
+export function getDriverDocumentsSummary(input: DriverDocumentsSummaryInput) {
+  if (input.globalStatus === 'all_approved') {
+    return {
+      title: 'Documents approuv�s',
+      subtitle: `${input.approved} document${input.approved > 1 ? 's' : ''} approuv�${input.approved > 1 ? 's' : ''} sur ${input.total}`,
+      helper: 'Tous vos documents requis ont �t� valid�s.',
+    }
+  }
+
+  if (input.globalStatus === 'has_rejected') {
+    return {
+      title: 'Action requise',
+      subtitle: `${input.rejected} document${input.rejected > 1 ? 's' : ''} � corriger`,
+      helper: 'Corrigez les documents refus�s pour relancer la v�rification.',
+    }
+  }
+
+  if (input.notSubmitted === input.total) {
+    return {
+      title: 'Documents � t�l�verser',
+      subtitle: `0 document approuv� sur ${input.total}`,
+      helper: 'T�l�versez tous les documents requis pour activer votre compte chauffeur.',
+    }
+  }
+
+  if (input.pending > 0 && input.approved === 0 && input.notSubmitted === 0) {
+    return {
+      title: 'V�rification en cours',
+      subtitle: `${input.pending} document${input.pending > 1 ? 's' : ''} en cours de v�rification`,
+      helper: 'Vos documents envoy�s sont en cours de v�rification.',
+    }
+  }
+
+  return {
+    title: 'V�rification en cours',
+    subtitle: `${input.approved} document${input.approved > 1 ? 's' : ''} approuv�${input.approved > 1 ? 's' : ''} sur ${input.total}`,
+    helper: 'Compl�tez les pi�ces manquantes et suivez la validation de vos documents.',
+  }
+}
