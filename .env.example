# Configuration des emails de vérification
# Copiez ce fichier dans functions/.env et adaptez les valeurs

# Clé API Resend (obligatoire)
RESEND_API_KEY=re_xxxxxxxxxxxxxx

# Email expéditeur
FROM_EMAIL=noreply@medjira-service.firebaseapp.com

# Nom expéditeur
FROM_NAME=Medjira Service

# Email de réponse
REPLY_TO=noreply@medjira-service.firebaseapp.com

# URL de l'application (sans slash final)
APP_URL=https://medjira-service.firebaseapp.com

# URL du logo pour les emails (doit être une URL publique HTTPS)
# Optionnel - laissez vide pour ne pas afficher de logo
LOGO_URL=

# Activer le logging des emails (true/false)
SHOULD_LOG_EMAILS=false

# Taux d'échantillonnage pour le logging (0.0 à 1.0)
LOG_SAMPLING_RATE=0.5

# ============================================================================
# Configuration Firebase Functions
# ============================================================================

# Région des fonctions Firebase (côté serveur - pour functions/.env)
FUNCTIONS_REGION=europe-west1

# Région des fonctions Firebase (côté client - pour Next.js)
# Utilisez cette variable dans votre code Next.js avec process.env.NEXT_PUBLIC_FIREBASE_FUNCTIONS_REGION
NEXT_PUBLIC_FIREBASE_FUNCTIONS_REGION=europe-west1

# ============================================================================
# Stripe Configuration
# ============================================================================
# Clé publique (exposée côté client — commence par pk_test_ ou pk_live_)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxx

# Clé secrète (serveur uniquement — commence par sk_test_ ou sk_live_)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxx

# Secret webhook (obtenu dans Dashboard Stripe > Webhooks — commence par whsec_)
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxx

# ============================================================================
# Google Maps API Keys
# ============================================================================
# Clé côté client (embarquée dans le bundle — restreindre via HTTP Referrers dans GCP)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clé côté serveur (JAMAIS dans le bundle — restreindre via IP serveur dans GCP)
GOOGLE_MAPS_SERVER_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL publique de l'application (sans slash final) — utilisée pour valider les URLs de retour Stripe
NEXT_PUBLIC_APP_URL=https://medjira-service.firebaseapp.com

# ============================================================================
# Twilio VoIP Configuration
# ============================================================================
# Server-side secrets (set via: firebase functions:secrets:set SECRET_NAME)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_OUTGOING_APPLICATION_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# Firebase Admin SDK (côté serveur — NE JAMAIS COMMIT LES VRAIES VALEURS)
# ============================================================================
# Utilisé par src/config/firebase-admin.ts et les scripts dans scripts/*.mjs
#
# Option 1 (RECOMMANDÉE) : pointer vers un fichier JSON hors du repo
#   GOOGLE_APPLICATION_CREDENTIALS=/chemin/absolu/hors-du-repo/serviceAccountKey.json
#
# Option 2 : variables individuelles (utile en CI / Vercel / Firebase Hosting)
FIREBASE_PROJECT_ID=medjira-service
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@medjira-service.iam.gserviceaccount.com
# Copier la valeur de "private_key" EN REMPLAÇANT les vrais retours à la ligne par \n littéraux.
# Exemple : "-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
