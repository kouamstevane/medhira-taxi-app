# Configuration des emails de vérification
# Copiez ce fichier dans functions/.env et adaptez les valeurs

# Clé API Resend (obligatoire)
RESEND_API_KEY=re_xxxxxxxxxxxxxx

# Email expéditeur
FROM_EMAIL=noreply@medjira-service.firebaseapp.com

# Nom expéditeur
FROM_NAME=Medjira Service

# Email de réponse
REPLY_TO=noreply@medjira-service.firebaseapp.com

# URL de l'application (sans slash final)
APP_URL=https://medjira-service.firebaseapp.com

# URL du logo pour les emails (doit être une URL publique HTTPS)
# Optionnel - laissez vide pour ne pas afficher de logo
LOGO_URL=

# Activer le logging des emails (true/false)
SHOULD_LOG_EMAILS=false

# Taux d'échantillonnage pour le logging (0.0 à 1.0)
LOG_SAMPLING_RATE=0.5

# ============================================================================
# Configuration Firebase Functions
# ============================================================================

# Région des fonctions Firebase (côté serveur - pour functions/.env)
FUNCTIONS_REGION=europe-west1

# Région des fonctions Firebase (côté client - pour Next.js)
# Utilisez cette variable dans votre code Next.js avec process.env.NEXT_PUBLIC_FIREBASE_FUNCTIONS_REGION
NEXT_PUBLIC_FIREBASE_FUNCTIONS_REGION=europe-west1

# ============================================================================
# Stripe Configuration
# ============================================================================
# Clé publique (exposée côté client — commence par pk_test_ ou pk_live_)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxx

# Clé secrète (serveur uniquement — commence par sk_test_ ou sk_live_)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxx

# Secret webhook (obtenu dans Dashboard Stripe > Webhooks — commence par whsec_)
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxx
