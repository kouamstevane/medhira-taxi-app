# Configuration Firebase (Client)
NEXT_PUBLIC_FIREBASE_API_KEY=votre_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=votre_projet.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=votre_projet
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=votre_projet.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=votre_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=votre_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=votre_measurement_id

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=votre_cle_google_maps

# Agora RTC (Appels VoIP)
# Obtenu depuis https://console.agora.io/
NEXT_PUBLIC_AGORA_APP_ID=votre_agora_app_id
# Activer uniquement si vous utilisez des tokens temporels (recommandé pour production)
# NEXT_PUBLIC_AGORA_ENABLE_CERT=true

# Configuration Admin (Serveur uniquement - NE PAS INCLURE DANS L'APP MOBILE)
FIREBASE_PROJECT_ID=votre_projet
FIREBASE_CLIENT_EMAIL=votre_service_account_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ============================================================================
# Configuration Resend Email (Firebase Functions)
# ============================================================================
# Clé API Resend pour l'envoi d'emails de vérification
# Obtenez votre clé API depuis https://resend.com/api-keys
# IMPORTANT: Cette variable doit être configurée dans Firebase Secret Manager
# ou via Firebase CLI: firebase functions:secrets:set RESEND_API_KEY
RESEND_API_KEY=your_resend_api_key_here

# Configuration des emails (optionnel - valeurs par défaut fournies)
# Email d'envoi (doit être vérifié dans Resend)
FROM_EMAIL=noreply@your-domain.com
# Nom de l'expéditeur
FROM_NAME=Your App Name
# Email de réponse (optionnel)
REPLY_TO=noreply@your-domain.com

# Configuration du logging Firestore (optionnel)
# Active/désactive le logging des emails dans Firestore
SHOULD_LOG_EMAILS=true
# Pourcentage de logs à conserver (0.0 à 1.0) - 50% par défaut
LOG_SAMPLING_RATE=0.5

# URL de l'application (optionnel - utilisé dans les liens des emails)
APP_URL=https://your-app.firebaseapp.com

# ============================================================================
# Configuration Firebase Functions
# ============================================================================
# Région de déploiement des fonctions Firebase (doit correspondre au déploiement)
# Valeurs courantes: europe-west1, us-central1, asia-east1, etc.
NEXT_PUBLIC_FIREBASE_FUNCTIONS_REGION=europe-west1
