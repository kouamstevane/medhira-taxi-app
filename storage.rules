rules_version = '2';

// Règles de sécurité pour Firebase Storage
service firebase.storage {
  match /b/{bucket}/o {
    
    // Images de profil des utilisateurs
    match /profile_images/{userId} {
      allow read: if true; // Les images de profil sont publiques
      allow write: if request.auth != null
                    && request.auth.uid == userId
                    && resource.contentType.matches('image/.*'); // Validation MIME type
    }
    
    // Documents des chauffeurs (permis, carte grise, etc.)
    // SÉCURITÉ: Restreint l'accès en lecture au propriétaire uniquement
    match /drivers/{driverId}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == driverId;
      allow write: if request.auth != null
                    && request.auth.uid == driverId
                    && (request.resource.contentType.matches('image/.*') || request.resource.contentType == 'application/pdf');
    }
    
    // Documents généraux liés aux chauffeurs
    // SÉCURITÉ: Restreint l'accès en lecture au propriétaire uniquement
    match /driver_documents/{driverId}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == driverId;
      allow write: if request.auth != null
                    && request.auth.uid == driverId
                    && (request.resource.contentType.matches('image/.*') || request.resource.contentType == 'application/pdf');
    }
    
    // Images des véhicules
    match /vehicles/{vehicleId}/{allPaths=**} {
      allow read: if true; // Les images de véhicules sont publiques
      allow write: if request.auth != null
                    && resource.contentType.matches('image/.*'); // Validation MIME type
    }
    
    // Documents de transaction/factures
    match /receipts/{userId}/{receiptId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Bloquer tout le reste par défaut
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

