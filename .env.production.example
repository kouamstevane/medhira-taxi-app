# ============================================================================
# .env.production — Variables embarquées dans le build PRODUCTION
# ============================================================================
#
# Ce fichier est un TEMPLATE. Copier en `.env.production` puis remplir.
# `.env.production` est ignoré par git.
#
# ⚠️ Ne PAS confondre avec `.env.example` qui couvre dev + variables serveur.
# Ici on liste UNIQUEMENT les variables nécessaires au build Next.js / Capacitor
# en production. Les secrets serveur (Stripe, Twilio, Resend, etc.) sont gérés
# par Google Cloud Secret Manager côté Firebase Functions — voir docs/SECRETS.md.
#
# Vérifications avant chaque build release :
#   1. Toutes les valeurs ci-dessous pointent vers la PROD (pas le projet dev)
#   2. Stripe en mode LIVE (`pk_live_…`)
#   3. Aucune valeur de test (clés `pk_test_`, projet `…-dev`, URL localhost)
# ============================================================================


# ─── Firebase (projet PROD — différent du projet de dev) ───────────────────
# Variables embarquées dans le bundle JS. Sécurisées par Firestore Rules + App Check.
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=medjira-prod.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=medjira-prod
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=medjira-prod.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Région des Cloud Functions (utilisée par le client pour httpsCallable)
NEXT_PUBLIC_FIREBASE_FUNCTIONS_REGION=europe-west1


# ─── Firebase Cloud Messaging (notifications push web) ─────────────────────
# Onglet Cloud Messaging → Web configuration → Web Push certificates
NEXT_PUBLIC_FCM_VAPID_KEY=BXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX


# ─── Stripe (mode LIVE en production) ──────────────────────────────────────
# ⚠️ DOIT commencer par `pk_live_` — `pk_test_` en prod = paiements échoués.
# La clé secrète `STRIPE_SECRET_KEY` est gérée par Secret Manager côté Functions
# (voir docs/SECRETS.md). Si le serveur Next.js (API routes) est aussi déployé,
# elle doit être configurée séparément sur l'hébergeur (Cloud Run, Vercel, etc.).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_XXXXXXXXXXXXXXXXXXXXXXXX


# ─── Google Maps (clé restreinte par SHA-1 du keystore release) ────────────
# Cette clé doit être restreinte dans Google Cloud Console à :
#   - Application : Android — package com.medjiraservice.medjiraserviceapp2
#                   + empreinte SHA-1 du keystore RELEASE (pas debug)
#   - APIs : Maps SDK for Android, Places, Directions, Geocoding
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX


# ─── Google Sign-In (OAuth) ────────────────────────────────────────────────
# Web Client ID du projet PROD — Console OAuth → Identifiants → Type Web
NEXT_PUBLIC_GOOGLE_WEB_CLIENT_ID=000000000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com


# ─── URLs publiques de production ──────────────────────────────────────────
# Utilisées pour : retours Stripe Connect, deep-links emails, return_url checkout.
# Doivent être HTTPS et sans slash final.
NEXT_PUBLIC_APP_URL=https://medjira.com
NEXT_PUBLIC_BASE_URL=https://medjira.com
NEXT_PUBLIC_API_URL=https://medjira.com


# ─── Configuration métier ──────────────────────────────────────────────────
NEXT_PUBLIC_DEFAULT_CITY_ID=edmonton


# ─── Build mobile (Capacitor) ──────────────────────────────────────────────
# Activer pour les builds destinés à Android/iOS (modifie next.config.ts).
MOBILE_BUILD=true
