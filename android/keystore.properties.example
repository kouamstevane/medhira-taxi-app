# ========================================
# Configuration de signature Android - Medjira Taxi
# ========================================
#
# RENAMEZ CE FICHRE EN "keystore.properties" ET REMPLISSEZ LES VALEURS
# NE COMMITTEZ PAS CE FICHIER SUR GIT!
#
# IMPORTANT: Sauvegardez ce fichier et votre keystore dans plusieurs
# endroits sécurisés. PERTE DU KEYSTORE = PERTE IRRÉVERSIBLE DE L'APP
#
# ========================================

# Chemin vers le fichier keystore (relatif au dossier android/app/)
MEDJIRA_KEYSTORE_FILE=medjira-release.keystore

# Mot de passe du keystore (créez-en un fort, 16+ caractères)
MEDJIRA_KEYSTORE_PASSWORD=votre_mot_de_passe_keystore_ici

# Alias de la clé (doit correspondre à celui utilisé lors de la création)
MEDJIRA_KEY_ALIAS=medjira

# Mot de passe de la clé (peut être le même que le keystore)
MEDJIRA_KEY_PASSWORD=votre_mot_de_passe_cle_ici

# ========================================
# Instructions:
#
# 1. Créez un keystore:
#    keytool -genkey -v -keystore android/app/medjira-release.keystore \
#    -alias medjira -keyalg RSA -keysize 2048 -validity 10000
#
# 2. Renommez ce fichier en "keystore.properties"
#
# 3. Remplacez les valeurs ci-dessus par vos vraies valeurs
#
# 4. Générez l'APK Release:
#    cd android && gradlew assembleRelease
#
# ========================================
