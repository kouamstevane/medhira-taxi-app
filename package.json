{
  "name": "medjira-taxi-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:mobile": "next dev --turbopack -H 0.0.0.0",
    "mobile:setup": "node scripts/setup-mobile-dev.js",
    "mobile:dev": "node scripts/dev-mobile.js",
    "build": "next build",
    "mobile:build": "node scripts/mobile-build.js",
    "mobile:sync": "npx cap sync",
    "mobile:open:android": "npx cap open android",
    "mobile:open:ios": "npx cap open ios",
    "mobile:run:android": "npx cap run android",
    "mobile:run:android:live": "npx cap run android --live-reload",
    "android:bundle": "node scripts/mobile-build.js && cd android && gradlew bundleRelease",
    "android:apk:release": "node scripts/mobile-build.js && cd android && gradlew assembleRelease",
    "start": "next start -p $PORT",
    "lint": "next lint .",
    "test": "jest --watch",
    "test:ci": "jest --ci --coverage",
    "test:coverage": "jest --coverage",
    "test:firestore": "jest --config jest.firestore.config.js",
    "test:firestore:emulators": "firebase emulators:exec \"jest --config jest.firestore.config.js\"",
    "optimize:images": "node optimize-images.js",
    "convert:svg": "node convert-svg-to-webp.js"
  },
  "dependencies": {
    "@capacitor-community/stripe": "^8.1.1",
    "@capacitor-firebase/authentication": "^8.1.0",
    "@capacitor-firebase/messaging": "^8.1.0",
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/camera": "^8.0.2",
    "@capacitor/core": "^8.3.0",
    "@capacitor/device": "^8.0.1",
    "@capacitor/geolocation": "^8.1.0",
    "@capacitor/google-maps": "^8.0.1",
    "@capacitor/haptics": "^8.0.1",
    "@capacitor/ios": "^8.3.0",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/network": "^8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/push-notifications": "^8.0.2",
    "@capgo/capacitor-social-login": "^8.3.8",
    "@gannonh/firebase-mcp": "^1.4.9",
    "@hookform/resolvers": "^5.2.2",
    "@react-google-maps/api": "^2.20.8",
    "@stripe/react-stripe-js": "^6.1.0",
    "@stripe/stripe-js": "^9.0.1",
    "@testing-library/dom": "^10.4.1",
    "@twilio/voice-sdk": "^2.18.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.7.0",
    "jspdf": "^4.2.1",
    "jose": "^6.2.2",
    "lucide-react": "^0.577.0",
    "next": "^16.2.3",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "react-hot-toast": "^2.6.0",
    "resend": "^6.9.3",
    "shadcn": "^4.0.8",
    "stripe": "^22.0.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.0",
    "@eslint/eslintrc": "^3",
    "@firebase/rules-unit-testing": "^5.0.0",
    "@google-cloud/firestore": "^7.5.0",
    "@playwright/test": "^1.59.1",
    "@swc/core": "^1.15.18",
    "@swc/jest": "^0.2.39",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.2",
    "firebase-functions": "^7.2.5",
    "firebase-tools": "^15.10.0",
    "imagemin": "^7.0.1",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "postcss": "^8.5.8",
    "sharp": "^0.34.5",
    "svgo": "^4.0.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5"
  },
  "overrides": {
    "protobufjs": "^7.5.5"
  },
  "description": "Application moderne de réservation de taxis et de livraison construite avec **Next.js 15**, **TypeScript**, **Firebase** et **Tailwind CSS**.",
